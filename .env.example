# ============================================================
# Sovereign Fraud Immunity Lab — Environment Variables
# Copy to .env and fill in values. NEVER commit .env itself.
# ============================================================

# -----------------------------------------------------------
# Kafka
# -----------------------------------------------------------
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_TRANSACTIONS=transactions
KAFKA_TOPIC_LOGINS=logins
KAFKA_TOPIC_DEVICES=devices
KAFKA_TOPIC_DETECTION_RESULTS=detection_results
KAFKA_TOPIC_ALERTS=alerts
KAFKA_CONSUMER_GROUP=fraud-immunity-group

# -----------------------------------------------------------
# Airflow
# -----------------------------------------------------------
AIRFLOW__CORE__SQL_ALCHEMY_CONN=postgresql+psycopg2://airflow:airflow@postgres:5432/airflow
AIRFLOW__CORE__FERNET_KEY=
AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW__WEBSERVER__SECRET_KEY=

# -----------------------------------------------------------
# Pinecone
# -----------------------------------------------------------
PINECONE_API_KEY=
PINECONE_ENVIRONMENT=us-east-1
PINECONE_INDEX_CLEAN=clean-profiles
PINECONE_INDEX_SUSPICIOUS=suspicious-profiles

# -----------------------------------------------------------
# Neo4j
# -----------------------------------------------------------
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=
NEO4J_DATABASE=neo4j

# -----------------------------------------------------------
# OpenAI
# -----------------------------------------------------------
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-large
OPENAI_AGENT_MODEL=gpt-4o

# -----------------------------------------------------------
# FastAPI
# -----------------------------------------------------------
API_SECRET_KEY=
API_ALLOWED_ORIGINS=http://localhost:3000
JWT_ALGORITHM=HS256
JWT_AUTH_ENABLED=true
# Dashboard login password for the built-in "admin" account
DASHBOARD_ADMIN_PASSWORD=
# Internal URL for server-to-server calls (Next.js RSC → FastAPI)
API_URL=http://localhost:8000
# Public URL for browser-side fetches (Next.js client → FastAPI)
NEXT_PUBLIC_API_URL=http://localhost:8000

# -----------------------------------------------------------
# Redis / Celery
# -----------------------------------------------------------
REDIS_URL=redis://localhost:6379/0

# -----------------------------------------------------------
# PostgreSQL (Airflow metadata + Immunity Score history)
# -----------------------------------------------------------
POSTGRES_USER=airflow
POSTGRES_PASSWORD=
POSTGRES_DB=airflow
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# -----------------------------------------------------------
# Feature Flags
# -----------------------------------------------------------
# Interval in seconds between demo alert events when Redis is unavailable
ALERT_FEED_INTERVAL_S=4.0
# Master kill-switch — MUST be false in production unless explicitly authorized
RED_TEAM_ENABLED=true
# If true, generates synthetic fraud but does NOT publish to Kafka
SYNTHETIC_INJECTION_DRY_RUN=false
